# OpenAI API Key (optional - for LLM chat functionality)
# If not provided, the system will use mock responses
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model to use
OPENAI_MODEL=gpt-3.5-turbo

# OpenAI API Base URL (for custom endpoints like OpenRouter)
# Leave empty to use default OpenAI endpoint
OPENAI_API_BASE_URL=

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend Configuration
FRONTEND_PORT=3000

# Temporary directories
TEMP_REPOS_DIR=./temp_repos
TEMP_INDICES_DIR=./temp_indices
